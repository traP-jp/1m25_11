BOT_TOKEN_KEY=bot_token_key_here
# Nitro 側の NUXT_PROXY_SECRET と同じ値を設定する。本番(APP_ENV=production)では必須。
# 本番で未設定のまま運用すると X-Forwarded-User を悪用したなりすましにつながるため、チェックをスキップしてはいけない。
PROXY_SECRET=
# APP_ENV は必須。開発環境は "development"、本番では "production" を設定すること。
# 本番(APP_ENV=production)にする場合は、必ず PROXY_SECRET も設定すること。
# DEV_USER フォールバックは開発環境(APP_ENV=development)でのみ有効。未設定では起動できない。
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
# 開発環境(APP_ENV=development)でのみ有効。X-Forwarded-Userヘッダーがない場合のフォールバック用traQ ID
DEV_USER=your_traq_id_here
