BOT_TOKEN_KEY=bot_token_key_here
# 開発環境は "development"、本番では "production" に変更すること。
# "production" 以外（未設定含む）では DEV_USER フォールバックが有効になる。
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
# 開発環境(APP_ENV=development)でのみ有効。X-Forwarded-Userヘッダーがない場合のフォールバック用traQ ID
DEV_USER=your_traq_id_here
