# 開発環境: クライアントからGoバックエンドへ直接通信
NUXT_PUBLIC_API_BASE=http://localhost:8080/api/v1
NUXT_BACKEND_API_URL=http://localhost:8080/api/v1

# 本番(NeoShowcase): Nitroプロキシ経由でX-Forwarded-Userを転送する
# NUXT_PUBLIC_API_BASE=/api/v1
# NUXT_BACKEND_API_URL=https://<バックエンドのURL>/api/v1
# NUXT_PROXY_SECRET=<サーバー側の PROXY_SECRET と同じ値>
